# Local Wrangler deploy credentials. Do not commit real values.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# PostHog analytics. The browser SDK uses the Cloudflare reverse proxy at
# /ingest so events stay on foundinpi.com before the Worker forwards them.
PUBLIC_POSTHOG_PROJECT_TOKEN=
PUBLIC_POSTHOG_HOST=/ingest
PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com
POSTHOG_PROJECT_TOKEN=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_ASSET_HOST=https://us-assets.i.posthog.com
