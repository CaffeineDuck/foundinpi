---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { env } from "cloudflare:workers";
import { getRelic, publicArtifactUrl, type EnvLike } from "../../lib/server/store";

export const prerender = false;

const relic = Astro.params.id
  ? await getRelic(env as EnvLike, Astro.params.id)
  : null;

if (!relic) {
  Astro.response.status = 404;
}

const canonical = relic
  ? new URL(`/r/${relic.id}`, Astro.url.origin).toString()
  : new URL("/museum", Astro.url.origin).toString();
const title = relic
  ? `${relic.title} - ${relic.rarity} Pi Relic`
  : "Pi Relic Not Found";
const description = relic
  ? `${relic.piNative.toFixed(1)}% pi-native. Longest fossil: ${relic.longestFossil} bytes. Recovered from ${relic.digSite}.`
  : "This pi relic could not be found.";
const artifactUrl = relic
  ? new URL(publicArtifactUrl(relic.artifactKey), Astro.url.origin).toString()
  : undefined;
const cardUrl = relic
  ? new URL(publicArtifactUrl(relic.cardKey), Astro.url.origin).toString()
  : undefined;
const robots = relic && relic.status !== "hidden" ? "index,follow" : "noindex,nofollow";
const jsonLd = relic
  ? {
      "@context": "https://schema.org",
      "@type": "ImageObject",
      name: relic.title,
      description,
      contentUrl: artifactUrl,
      thumbnailUrl: cardUrl,
      dateCreated: relic.createdAt,
      creator: {
        "@type": "Organization",
        name: "Found in Pi"
      }
    }
  : undefined;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  image={cardUrl}
  robots={robots}
  jsonLd={jsonLd}
>
  {
    relic ? (
      <main class="result-shell">
        <header class="result-nav">
          <a href="/" class="wordmark">Found in Pi</a>
          <div class="header-links">
            <a href="/museum">Museum</a>
            <a href="/random">Random</a>
          </div>
        </header>

        <section class="result-hero">
          <div class="result-image-wrap">
            <img
              src={artifactUrl}
              alt={`${relic.title} reconstructed pi relic`}
              width="960"
              height="720"
            />
          </div>
          <article class="result-report">
            <p class="eyebrow">Recovered Artifact</p>
            <h1>{relic.title}</h1>
            <p class="result-summary">{description}</p>
            <div class="result-score">
              <strong>{relic.piNative.toFixed(1)}%</strong>
              <span>pi-native</span>
            </div>
            <div class="result-rarity">{relic.rarity}</div>
            <dl class="result-metrics">
              <div>
                <dt>Exact Pi</dt>
                <dd>{relic.exactPct.toFixed(1)}%</dd>
              </div>
              <div>
                <dt>Near Pi</dt>
                <dd>{relic.nearPct.toFixed(1)}%</dd>
              </div>
              <div>
                <dt>Lossy Pi</dt>
                <dd>{relic.lossyPct.toFixed(1)}%</dd>
              </div>
              <div>
                <dt>Earth Bytes</dt>
                <dd>{relic.earthPct.toFixed(1)}%</dd>
              </div>
            </dl>
            <div class="map-block">
              <span class="map-caption">Excavation map</span>
              <div
                class="excavation-map"
                role="img"
                aria-label={`Excavation map, ${relic.piNative.toFixed(1)} percent pi-native`}
              >
                {relic.shareGrid.split("\n").map((row) => (
                  <div class="map-row">
                    {Array.from(row).map((glyph) => (
                      <i
                        data-k={glyph === "🟩"
                          ? "exact"
                          : glyph === "🟨"
                            ? "near"
                            : glyph === "⬜"
                              ? "lossy"
                              : "earth"}
                      />
                    ))}
                  </div>
                ))}
              </div>
            </div>
            <p class="truth-note result-truth">
              Found in Pi searches a finite indexed region of pi. Scores are
              excavation scores, not compression claims.
            </p>
            <a class="primary-link" href="/">Excavate your image</a>
          </article>
        </section>

        <script is:inline define:vars={{ id: relic.id }}>
          const sampleRate = 64;
          const repeatWindowMs = 6 * 60 * 60 * 1000;
          const storageKey = `found-in-pi:view:${id}`;
          let shouldSample = true;

          try {
            const lastView = Number(localStorage.getItem(storageKey) || "0");
            shouldSample = Date.now() - lastView > repeatWindowMs;
            if (shouldSample) {
              localStorage.setItem(storageKey, String(Date.now()));
            }
          } catch {
            shouldSample = true;
          }

          if (shouldSample) {
            const random = new Uint32Array(1);
            crypto.getRandomValues(random);

            if (random[0] % sampleRate === 0) {
              const payload = new Blob(
                [JSON.stringify({ weight: sampleRate })],
                { type: "application/json" }
              );
              const endpoint = `/api/relics/${id}/view`;
              const sent = navigator.sendBeacon?.(endpoint, payload) ?? false;

              if (!sent) {
                fetch(endpoint, {
                  method: "POST",
                  body: payload,
                  keepalive: true
                }).catch(() => undefined);
              }
            }
          }
        </script>
      </main>
    ) : (
      <main class="missing-shell">
        <a href="/" class="wordmark">Found in Pi</a>
        <h1>Relic not found</h1>
        <a class="primary-link" href="/museum">Open the museum</a>
      </main>
    )
  }
</BaseLayout>
