---
import "../styles/global.css";

type Props = {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  robots?: string;
  jsonLd?: Record<string, unknown>;
};

const {
  title,
  description,
  canonical = Astro.url.href,
  image,
  robots = "index,follow",
  jsonLd
} = Astro.props;
const siteName = "Found in Pi";
const ogImage =
  image ?? new URL("/og/foundinpi-v3.png", Astro.url.origin).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;600;700;800;900&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" content="#d7d5ce" />
    {
      jsonLd ? (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(jsonLd)}
        />
      ) : null
    }
  </head>
  <body>
    <div class="page-atmosphere" aria-hidden="true"></div>
    <slot />
    <footer class="site-footer">
      <span>Found in Pi</span>
      <a href="/about">About</a>
      <a href="https://github.com/caffeineduck/foundinpi" rel="noreferrer">
        GitHub
      </a>
      <a href="https://x.com/caffe1neduck" rel="noreferrer">
        Twitter @caffe1neduck
      </a>
    </footer>
  </body>
</html>
